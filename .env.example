# FOUNDATION enthaelt noch keine externen Integrationen oder Zugangsdaten.
NODE_ENV=development
WORKER_HOST=127.0.0.1
WORKER_PORT=3001

# Nur lokale Platzhalter; niemals echte Zugangsdaten committen.
DATABASE_MIGRATION_URL=postgresql://builder_migrator:LOCAL_MIGRATION_PASSWORD@127.0.0.1:5432/software_builder
# Nur waehrend eines lokalen Wartungsfensters zusammen mit ALLOW_DATABASE_MAINTENANCE=YES setzen.
DATABASE_MAINTENANCE_CONFIRM=local-only:software_builder
# Muss die separate Runtime-LOGIN-Rolle verwenden; niemals den Migrator.
DATABASE_URL=postgresql://builder_app_login:DIFFERENT_LOCAL_RUNTIME_PASSWORD@127.0.0.1:5432/software_builder
CONTEXT_DATABASE_URL=postgresql://builder_context_login:THIRD_DISTINCT_LOCAL_PASSWORD@127.0.0.1:5432/software_builder
CLAIM_DATABASE_URL=postgresql://builder_claim_login:FOURTH_DISTINCT_LOCAL_PASSWORD@127.0.0.1:5432/software_builder
# Integrationstests laufen ausschliesslich mit einer separaten Test-Datenbank.
TEST_DATABASE_URL=postgresql://builder_migrator:LOCAL_PASSWORD@127.0.0.1:5432/software_builder_test
