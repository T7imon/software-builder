{
  "name": "software-builder",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "npm run build --workspace @software-builder/core",
    "dev": "concurrently --kill-others-on-fail --names web,worker \"npm run dev --workspace @software-builder/web\" \"npm run dev --workspace @software-builder/worker\"",
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint apps packages",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.0",
    "eslint-config-next": "^16.1.0",
    "globals": "^16.5.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.50.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=24"
  }
}
